<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- DYNAMIC BACKGROUND (Preserves rounded corners + allows Opacity) -->
    <ImageView
        android:id="@+id/widget_bg_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/widget_background"
        android:scaleType="fitXY" />

    <!-- CONTENT CONTAINER WITH PADDING -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <!-- TOP ROW - THREE PILLS - No background, floating labels -->
        <LinearLayout
            android:id="@+id/top_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical|center_horizontal"
            android:layout_alignParentTop="true"
            android:layout_toStartOf="@+id/widget_btn_settings"
            android:weightSum="3">
            
            <!-- OIL PILL -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:orientation="horizontal"
                android:gravity="center">
                <ImageView
                    android:id="@+id/widget_oil_dot"
                    android:layout_width="7dp"
                    android:layout_height="7dp"
                    android:src="@drawable/widget_oil_dot" />
                <TextView
                    android:id="@+id/widget_oil_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="OIL: 0"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- TRIP PILL -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:orientation="horizontal"
                android:gravity="center">
                <ImageView
                    android:id="@+id/widget_trip_dot"
                    android:layout_width="7dp"
                    android:layout_height="7dp"
                    android:src="@drawable/widget_oil_dot"
                    android:tint="#00f0ff" />
                <TextView
                    android:id="@+id/widget_trip_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="TRIP: 0"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- BUDGET PILL -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:orientation="horizontal"
                android:gravity="center">
                <ImageView
                    android:id="@+id/widget_budget_dot"
                    android:layout_width="7dp"
                    android:layout_height="7dp"
                    android:src="@drawable/widget_oil_dot"
                    android:tint="#f0ff00" />
                <TextView
                    android:id="@+id/widget_budget_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="50 EGP"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
        
        <!-- SETTINGS (3-DOT) BUTTON -->
        <ImageView
            android:id="@+id/widget_btn_settings"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:padding="4dp"
            android:layout_marginTop="-4dp"
            android:layout_marginEnd="-4dp"
            android:src="@drawable/ic_more_vert" />

        <!-- CENTER ROW (SPEED GAUGE) -->

        <ImageView
            android:id="@+id/widget_gauge_img"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@+id/top_row"
            android:layout_above="@+id/bottom_row"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="-16dp"
            android:scaleType="fitCenter" />

        <!-- BOTTOM ROW -->
        <LinearLayout
            android:id="@+id/bottom_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_alignParentBottom="true">
            
            <TextView
                android:id="@+id/widget_range_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="85.4 KM"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="6dp">
                
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#1AFFFFFF" />
                    
                <ImageView
                    android:id="@+id/widget_fuel_progress_fill"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/widget_progress_clip" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:weightSum="3">
                
                <TextView
                    android:id="@+id/widget_fuel_left_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="start"
                    android:text="2.1 L"
                    android:textColor="#99FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <!-- ODO IN THE BOTTOM CENTER -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="horizontal">
                    <ImageView
                        android:id="@+id/widget_odo_dot"
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:src="@drawable/widget_oil_dot"
                        android:tint="#ffffff" />
                    <TextView
                        android:id="@+id/widget_odo_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="3dp"
                        android:text="ODO: 0"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/widget_empty_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="EMPTY: 1024 KM"
                    android:textColor="#99FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>

</RelativeLayout>
